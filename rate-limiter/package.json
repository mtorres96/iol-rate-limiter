{
  "name": "rate-limiter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express/index.d.ts",
      "import": "./dist/adapters/express/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "verify": "npm run typecheck && vitest run --coverage && npm run lint",
    "build": "tsup",
    "start": "node dist/demo/server.js",
    "dev": "tsx watch src/demo/server.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@testcontainers/redis": "^12.0.3",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "4.1.9",
    "dockerode": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "openapi-types": "^12.1.3",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "~5.9",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "express": ">=5",
    "ioredis": "^5.11.1",
    "swagger-ui-express": "^5.0.1"
  },
  "peerDependencies": {
    "express": ">=5"
  }
}
